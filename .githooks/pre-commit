#!/usr/bin/env bash

echo "====================================================="
echo "🔍 Ejecutando Pre-commit Hook: Análisis de Linters"
echo "====================================================="

# Busquem el directori arrel del projecte Git
PROJECT_ROOT=$(git rev-parse --show-toplevel)

# Executar el linter de Gradle fent servir la ruta absoluta al gradlew
# Això evita l'error de "Unable to access jarfile"
"$PROJECT_ROOT/gradlew" -p "$PROJECT_ROOT" check --daemon

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ ERROR: El código no cumple con las reglas de formato o sintaxis."
  echo "Por favor, revisa los errores del linter (o SonarLint local) y vuelve a intentarlo."
  echo "====================================================="
  exit 1
fi

echo "✅ Análisis de formato superado. Procediendo con el commit..."
exit 0