#!/usr/bin/env bash

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Regex: Empieza por TG[, números, ]:, tipo (feat|fix|docs), :, espacio literal, y texto.
REGEX="^TG\[[0-9]+\]:(feat|fix|docs): .+"

if [[ ! $COMMIT_MSG =~ $REGEX ]]; then
  echo "=================================================================="
  echo "❌ ERROR: El mensaje del commit no cumple con la nomenclatura."
  echo "La metodología exige la siguiente sintaxis estricta:"
  echo "  TG[<ID>]:<tipo>: <mensaje explicativo>"
  echo ""
  echo "Tipos permitidos: feat, fix, docs"
  echo "Ejemplo válido: TG[45]:feat: text del commit"
  echo "=================================================================="
  exit 1
fi

exit 0