# ==========================================
# 2. Arxius de Gradle i Compilació
# ==========================================
.gradle/
/.gradle/
build/
/build/
*/build/
# Mai ignorem el wrapper de Gradle, aquest SÍ que s'ha de pujar:
!gradle/wrapper/gradle-wrapper.jar

